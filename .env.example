# Used only by Netlify Functions (set in Netlify UI → Site settings → Environment variables).
# Do not put this in the browser. Local testing: `netlify dev` reads a root `.env` file.
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
