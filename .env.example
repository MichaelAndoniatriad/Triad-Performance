# Used only by Netlify Functions. Local: `netlify dev` reads this file.
# On Netlify: use Integrations → Neon (sets NETLIFY_DATABASE_URL) OR add DATABASE_URL manually.
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
#
# If you use Neon’s pooled / serverless connection string in the dashboard, prefer that for functions.
